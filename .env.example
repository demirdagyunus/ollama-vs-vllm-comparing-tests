# Copy to `.env` and customise for local runs (`source scripts/setup_environment.sh` loads it).

# Target endpoints mirrored by compose services
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000

# Scenario scripts default model identifiers
OLLAMA_MODEL=qwen3:4b
VLLM_MODEL=Qwen/Qwen3-4B

# Scenario output folders (defaults keep repo-relative paths inside cases/results)
OUTPUT_DIR_SCENARIO1=
OUTPUT_DIR_SCENARIO2=
OUTPUT_DIR_SCENARIO3=
OUTPUT_DIR_SCENARIO4=

# Optional concurrency overrides passed to argparse (space-separated ints)
LEVELS_SCENARIO1="10 50 100"
